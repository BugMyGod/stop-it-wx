.brand {
  margin-bottom: 24rpx;
}

.brand-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #0f172a;
}

.brand-slogan {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #2fa394;
}

.brand-desc {
  margin-top: 8rpx;
  color: #4b5563;
  font-size: 25rpx;
}

.section {
  margin-bottom: 24rpx;
}

.loading {
  margin-top: 10rpx;
}

.template-grid {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
}

.input-area {
  width: 100%;
  min-height: 170rpx;
  background: #f9fafb;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 18rpx;
  box-sizing: border-box;
  font-size: 27rpx;
}

.generate-btn {
  margin-top: 8rpx;
}
