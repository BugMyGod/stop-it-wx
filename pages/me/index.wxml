<view class="container">
  <view class="card profile-card">
    <view class="title">StopIt回应助手</view>
    <view class="subtle">拒绝是你的权利，不必解释太多。</view>
    <view class="user-line" wx:if="{{loggedIn}}">
      <text class="label">当前账号：</text>
      <text class="value">{{userDisplay}}</text>
    </view>
    <view class="user-line" wx:else>
      <text class="subtle">当前未登录</text>
    </view>
  </view>

  <view class="card menu-card">
    <view class="menu-item" bindtap="goFavorites">
      <text>我的收藏</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goHistory">
      <text>我的历史</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goFeedback">
      <text>意见反馈</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="showAbout">
      <text>关于产品</text>
      <text class="arrow">></text>
    </view>
  </view>

  <button class="{{authBtnClass}} auth-btn" bindtap="handleAuthAction">
    {{authBtnText}}
  </button>
</view>
