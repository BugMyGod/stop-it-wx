.loading-card {
  color: #4b5563;
}

.history-item {
  margin-bottom: 16rpx;
}

.summary {
  font-size: 28rpx;
  color: #111827;
  line-height: 1.7;
}

.meta-row {
  margin-top: 12rpx;
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.tone {
  font-size: 22rpx;
  color: #0f766e;
  border-radius: 8rpx;
  background: #ecfdf5;
  border: 1rpx solid #b2e5dc;
  padding: 4rpx 10rpx;
}

.category {
  font-size: 22rpx;
  color: #6b7280;
}

.time {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.actions {
  margin-top: 16rpx;
  display: flex;
  gap: 12rpx;
}

.small-btn {
  margin: 0;
}
