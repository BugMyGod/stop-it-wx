.feedback-input {
  width: 100%;
  min-height: 180rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
  background: #f9fafb;
}

.label {
  margin-top: 20rpx;
  margin-bottom: 8rpx;
  font-size: 24rpx;
  color: #374151;
}

.contact-input {
  width: 100%;
  height: 84rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
  background: #f9fafb;
}

.submit-btn {
  margin-top: 22rpx;
}
