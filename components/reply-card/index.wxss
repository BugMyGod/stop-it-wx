.reply-card {
  background: #ffffff;
  border: 1rpx solid #dde3e8;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 18rpx;
}

.header {
  margin-bottom: 10rpx;
}

.style {
  display: inline-block;
  color: #0f766e;
  background: #ecfdf5;
  border: 1rpx solid #b2e5dc;
  border-radius: 8rpx;
  font-size: 22rpx;
  padding: 4rpx 10rpx;
}

.text {
  color: #111827;
  font-size: 28rpx;
  line-height: 1.7;
}

.note {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.mini-btn {
  margin: 0;
  border-radius: 10rpx;
  border: 1rpx solid #d1d5db;
  color: #374151;
  background: #ffffff;
  font-size: 24rpx;
  line-height: 1.8;
  padding: 0 16rpx;
}
