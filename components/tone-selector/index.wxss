.tone-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tone-item {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid #d1d5db;
  color: #374151;
  font-size: 24rpx;
  background: #ffffff;
}

.tone-item--active {
  border-color: #2fa394;
  color: #0f766e;
  background: #ecfdf5;
}
